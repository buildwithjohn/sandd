# ============================================================
# SandD Prophetic School — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bunny.net (get from your Bunny.net stream library)
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your-library-id
BUNNY_API_KEY=your-bunny-api-key

# App URL
NEXT_PUBLIC_APP_URL=https://sandd.abiodunsule.uk

# Email (optional — for application notifications)
# RESEND_API_KEY=your-resend-api-key
